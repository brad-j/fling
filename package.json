{
  "name": "fling",
  "version": "0.1.0",
  "description": "Fling files to remote machines over SSH — from your menubar",
  "author": "brad-j",
  "license": "MIT",
  "private": true,
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "icons:generate": "node scripts/generate-icons.mjs",
    "prepare:dist": "pnpm icons:generate && pnpm typecheck && pnpm build",
    "pack:mac": "pnpm prepare:dist && CSC_IDENTITY_AUTO_DISCOVERY=false SKIP_NOTARIZE=true electron-builder --mac --dir",
    "dist:mac:unsigned": "pnpm prepare:dist && CSC_IDENTITY_AUTO_DISCOVERY=false SKIP_NOTARIZE=true electron-builder --mac dmg zip",
    "dist:mac": "pnpm prepare:dist && electron-builder --mac dmg zip",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "electron-store": "^10.0.1",
    "menubar": "^9.5.1",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ssh2": "^1.15.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
